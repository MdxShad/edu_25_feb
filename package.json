{
  "name": "educonnect-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "npm run test:permissions && npm run test:commission && npm run test:pdf",
    "test:permissions": "tsx --test src/tests/permissions.test.ts",
