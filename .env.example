# Required
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/educonnect?schema=public"
SECURITY_HASH_SALT="replace-with-a-long-random-secret-at-least-24-characters"

# Session
SESSION_COOKIE_NAME="educonnect_session"
SESSION_TTL_DAYS="14"

# Public URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Uploads
UPLOADS_ENABLED="true"
BLOB_READ_WRITE_TOKEN=""

# Optional AI features
AI_FEATURES_ENABLED="false"
NEXT_PUBLIC_AI_FEATURES_ENABLED="false"
OPENAI_API_KEY=""
OPENAI_MODEL=""

# Optional PDF terms overrides
PDF_TERMS_ADMISSION_SLIP=""
PDF_TERMS_FEE_RECEIPT=""
PDF_TERMS_UNIVERSITY_PAYMENT=""
PDF_TERMS_AGENT_PAYOUT=""
PDF_TERMS_REPORT=""
